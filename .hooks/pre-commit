#!/bin/sh
#
# Pre-commit hook: ensure Prisma schema changes always ship with a migration
# and vice versa. Prevents the "committed schema without migration" drift
# that caused the 2026-04-01 production outage.

SCHEMA="server/src/db/prisma/schema.prisma"
MIGRATIONS_DIR="server/src/db/prisma/migrations"

# Check what's staged
schema_changed=$(git diff --cached --name-only -- "$SCHEMA")
new_migration=$(git diff --cached --name-only --diff-filter=A -- "$MIGRATIONS_DIR/*/migration.sql")

if [ -n "$schema_changed" ] && [ -z "$new_migration" ]; then
  echo ""
  echo "ERROR: schema.prisma is staged but no new migration file was added."
  echo ""
  echo "  Every schema change needs a migration. Run:"
  echo "    cd server && npm run db:migrate -- --name your_change_name"
  echo ""
  echo "  Then stage both the schema and the migration together."
  echo "  To bypass (ONLY for non-model changes like comments): git commit --no-verify"
  echo ""
  exit 1
fi

if [ -z "$schema_changed" ] && [ -n "$new_migration" ]; then
  echo ""
  echo "ERROR: A new migration file is staged but schema.prisma is not."
  echo ""
  echo "  Schema and migration must always be committed together."
  echo "  Stage schema.prisma:  git add $SCHEMA"
  echo ""
  exit 1
fi

# Reject hand-written .sql files directly in the migrations directory (not in subdirectories)
# Use grep to exclude files inside timestamped subdirs (which are legitimate Prisma migrations)
loose_sql=$(git diff --cached --name-only --diff-filter=A -- "$MIGRATIONS_DIR" | grep -E "^${MIGRATIONS_DIR}/[^/]+\.sql$" || true)
if [ -n "$loose_sql" ]; then
  echo ""
  echo "ERROR: Loose .sql file(s) added to migrations directory:"
  echo "$loose_sql"
  echo ""
  echo "  All migration SQL must live inside a timestamped subdirectory,"
  echo "  generated by 'prisma migrate dev'. Never hand-write standalone SQL files."
  echo ""
  exit 1
fi
