generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(uuid())
  appleUserId          String?         @unique
  email                String?         @unique
  passwordHash         String?
  name                 String          @default("Default User")
  createdAt            DateTime        @default(now())
  // Profile fields
  heightCm             Float?
  weightKg             Float?
  sex                  Sex             @default(UNSPECIFIED)
  dateOfBirth          DateTime?       @db.Date
  activityLevel        ActivityLevel?
  preferredUnits       UnitSystem      @default(METRIC)
  currentGoalProfileId String?

  // Relations
  dailyGoal            DailyGoal?
  foodEntries          FoodEntry[]
  customFoods          CustomFood[]
  voiceSessions        VoiceSession[]
  goalProfiles         GoalProfile[]
  currentGoalProfile   GoalProfile?    @relation("CurrentGoalProfile", fields: [currentGoalProfileId], references: [id])
  goalTimelineEntries  GoalTimeline[]      @relation("UserGoalTimeline")
  unitConversions      FoodUnitConversion[]
  createdCommunityFoods CommunityFood[]        @relation("CommunityFoodCreator")
  createdBarcodes       CommunityFoodBarcode[] @relation("BarcodeCreator")
  foodReports           CommunityFoodReport[]  @relation("FoodReporter")
  suppressUsdaWarning   Boolean                @default(false)
  savedMeals            SavedMeal[]
  refreshTokens         RefreshToken[]
  passwordResets        PasswordReset[]
  searchLogs            SearchLog[]
  weightEntries         WeightEntry[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

model DailyGoal {
  id        String @id @default(uuid())
  userId    String @unique
  calories  Int
  proteinG  Float
  carbsG    Float
  fatG      Float
  user      User   @relation(fields: [userId], references: [id])
}

model FoodEntry {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  mealLabel    MealLabel
  name         String
  calories     Float
  proteinG     Float
  carbsG       Float
  fatG         Float
  quantity     Float
  unit         String
  source          FoodSource
  usdaFdcId       Int?
  customFoodId    String?
  communityFoodId String?
  confirmedViaScale Boolean  @default(false)
  voiceSessionId  String?
  savedMealId     String?
  mealInstanceId  String?
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  customFood    CustomFood?    @relation(fields: [customFoodId], references: [id])
  communityFood CommunityFood? @relation(fields: [communityFoodId], references: [id])
  voiceSession  VoiceSession?  @relation(fields: [voiceSessionId], references: [id])

  @@index([userId, date])
  @@index([userId, date, voiceSessionId])
  @@index([userId, name])
}

model CustomFood {
  id             String               @id @default(uuid())
  userId         String
  name           String
  brandName      String?
  servingSize    Float
  servingUnit    String
  calories       Float
  proteinG       Float
  carbsG         Float
  fatG           Float
  sodiumMg       Float?
  cholesterolMg  Float?
  fiberG         Float?
  sugarG         Float?
  saturatedFatG  Float?
  transFatG      Float?
  barcode        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user        User                  @relation(fields: [userId], references: [id])
  foodEntries FoodEntry[]
  unitConfigs FoodUnitConversion[]

  @@index([userId, name])
  @@index([userId, barcode])
}

model SavedMeal {
  id        String          @id @default(uuid())
  userId    String
  name      String
  items     SavedMealItem[]
  user      User            @relation(fields: [userId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

model SavedMealItem {
  id              String    @id @default(uuid())
  savedMealId     String
  savedMeal       SavedMeal @relation(fields: [savedMealId], references: [id], onDelete: Cascade)
  name            String
  quantity        Float
  unit            String
  calories        Float
  proteinG        Float
  carbsG          Float
  fatG            Float
  source          FoodSource
  usdaFdcId       Int?
  customFoodId    String?
  communityFoodId String?
}

model VoiceSession {
  id          String        @id @default(uuid())
  userId      String
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  status      SessionStatus @default(active)
  user        User          @relation(fields: [userId], references: [id])
  foodEntries FoodEntry[]

  @@index([userId])
}

/// Per-food unit definitions that map friendly units (slice, cup, piece)
/// to the food's base serving size (servingSize + servingUnit).
/// Used to keep macros tied to a single canonical base while allowing
/// users to log with alternative units.
model FoodUnitConversion {
  id                 String   @id @default(uuid())
  userId             String
  customFoodId       String?
  usdaFdcId          Int?
  /// Name of the user-facing unit (e.g. "slice", "cup").
  unitName           String
  /// How many base servings this unit represents.
  /// For example, if the base serving is "100 g" and the user defines
  /// 1 slice = 30 g, then quantityInBaseServings = 0.3.
  quantityInBaseServings Float
  /// Measurement system for the unit: 'weight', 'volume', or 'abstract'.
  /// Used for consistency checks and cascade updates.
  measurementSystem  String   @default("abstract")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  customFood CustomFood? @relation(fields: [customFoodId], references: [id])

  @@index([userId, customFoodId, unitName])
  @@index([userId, usdaFdcId, unitName])
}

model GoalProfile {
  id             String        @id @default(uuid())
  userId         String
  name           String
  createdAt      DateTime      @default(now())
  archivedAt     DateTime?

  user           User          @relation(fields: [userId], references: [id])
  goalEntries    GoalTimeline[]
  currentForUsers User[]       @relation("CurrentGoalProfile")
}

model GoalTimeline {
  id             String             @id @default(uuid())
  userId         String
  profileId      String?
  effectiveDate  DateTime           @db.Date
  calories       Int
  proteinG       Float
  carbsG         Float
  fatG           Float
  goalType       GoalType
  aggressiveness GoalAggressiveness
  createdAt      DateTime           @default(now())

  user           User               @relation("UserGoalTimeline", fields: [userId], references: [id])
  profile        GoalProfile?       @relation(fields: [profileId], references: [id])

  @@index([userId, effectiveDate(sort: Desc)])
  @@index([profileId, effectiveDate])
}

model CommunityFood {
  id                 String              @id @default(uuid())
  name               String
  brandName          String?
  description        String?
  defaultServingSize Float
  defaultServingUnit String
  calories           Float
  proteinG           Float
  carbsG             Float
  fatG               Float
  sodiumMg           Float?
  cholesterolMg      Float?
  fiberG             Float?
  sugarG             Float?
  saturatedFatG      Float?
  transFatG          Float?
  usdaFdcId          Int?
  createdByUserId    String?
  status             CommunityFoodStatus @default(ACTIVE)
  usesCount          Int                 @default(0)
  reportsCount       Int                 @default(0)
  trustScore         Float               @default(0.5)
  lastUsedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  createdBy   User?                @relation("CommunityFoodCreator", fields: [createdByUserId], references: [id])
  foodEntries FoodEntry[]
  barcodes    CommunityFoodBarcode[]
  reports     CommunityFoodReport[]

  @@index([name])
  @@index([status])
  @@index([usdaFdcId])
}

model CommunityFoodBarcode {
  id              String      @id @default(uuid())
  barcode         String      @unique
  type            BarcodeType @default(OTHER)
  communityFoodId String
  createdByUserId String?
  createdAt       DateTime    @default(now())

  communityFood CommunityFood @relation(fields: [communityFoodId], references: [id])
  createdBy     User?         @relation("BarcodeCreator", fields: [createdByUserId], references: [id])
}

model CommunityFoodReport {
  id              String   @id @default(uuid())
  communityFoodId String
  reporterUserId  String?
  reason          String
  details         String?
  createdAt       DateTime @default(now())

  communityFood CommunityFood @relation(fields: [communityFoodId], references: [id])
  reporter      User?         @relation("FoodReporter", fields: [reporterUserId], references: [id])
}

model USDAFoodMetrics {
  fdcId      Int       @id
  usesCount  Int       @default(0)
  trustScore Float     @default(0.5)
  lastUsedAt DateTime?
  updatedAt  DateTime  @updatedAt

  @@index([usesCount(sort: Desc)])
}

model SearchLog {
  id              String      @id @default(uuid())
  userId          String
  query           String
  normalizedQuery String
  selectedFoodRef String?
  selectedName    String?
  source          FoodSource?
  resultStatus    String
  createdAt       DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([query])
}

model WeightEntry {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  weightKg  Float
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
}

enum MealLabel {
  breakfast
  lunch
  dinner
  snack
}

enum FoodSource {
  DATABASE
  CUSTOM
  COMMUNITY
  AI_ESTIMATE
}

enum CommunityFoodStatus {
  ACTIVE
  PENDING
  RETIRED
}

enum BarcodeType {
  UPC_A
  EAN_13
  CODE_128
  OTHER
}

enum SessionStatus {
  active
  completed
  cancelled
}

enum Sex {
  MALE
  FEMALE
  UNSPECIFIED
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  HIGH
  VERY_HIGH
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum GoalType {
  CUT
  MAINTAIN
  GAIN
}

enum GoalAggressiveness {
  MILD
  STANDARD
  AGGRESSIVE
}
