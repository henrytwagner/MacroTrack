{
  "name": "dialed-server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate --schema=src/db/prisma/schema.prisma && tsc",
    "start": "node dist/server/src/server.js",
    "db:generate": "prisma generate --schema=src/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/db/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=src/db/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=src/db/prisma/schema.prisma",
    "db:migrate:diff": "prisma migrate diff --from-migrations-directory src/db/prisma/migrations --to-schema-datamodel src/db/prisma/schema.prisma --shadow-database-url \"$SHADOW_DATABASE_URL\"",
    "db:push": "echo '⚠️  db:push does not create migrations — use db:migrate instead unless prototyping' && prisma db push --schema=src/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/db/prisma/schema.prisma",
    "test": "jest",
    "decode-barcode": "tsx scripts/decode-barcode-from-file.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.46.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@types/bcrypt": "^6.0.0",
    "@zxing/library": "^0.20.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "jose": "^6.2.2",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "resend": "^6.9.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
