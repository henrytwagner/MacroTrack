{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:clear": "npm run kill:8081 && expo start --clear",
    "predev": "rm -rf .expo 2>/dev/null; npm run clean:cache; echo ''; echo '► Metro will start below on port 8081. Leave this terminal open.'; echo '► If Metro asks \"Use port 8082?\", say No (n), then run: npm run kill:8081  and try again.'; echo '► In a second terminal (same folder): npx expo run:ios  (or  npx expo run:ios --device)'; echo '► Or press i here after Metro is ready to open the app.'; echo ''",
    "start:dev": "npm run kill:8081 && npm run predev && expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "clean:cache": "rm -rf node_modules/.cache 2>/dev/null; rm -rf $TMPDIR/haste-map-* 2>/dev/null; rm -rf $TMPDIR/metro-cache 2>/dev/null; echo 'Bundler cache cleared.'",
    "kill:8081": "lsof -ti :8081 | xargs kill -9 2>/dev/null; echo 'Freed port 8081 (if anything was using it).'",
    "ios:device:clean": "npm run clean:cache && expo run:ios --device --no-build-cache",
    "ios:with-fresh-bundle": "npm run clean:cache && expo run:ios",
    "ios:device:with-fresh-bundle": "npm run clean:cache && expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@zxing/library": "^0.20.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.3",
    "expo-image-picker": "~17.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~52.0.2",
    "ts-jest": "~29.2.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
