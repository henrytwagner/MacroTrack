    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@zxing/library": "^0.20.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
